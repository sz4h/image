{
  "name": "sz4h/image",
  "description": "This image on the fly resize package",
  "keywords": [
    "sz4h",
    "space",
    "laravel",
    "image"
  ],
  "homepage": "https://github.com/space/image",
  "license": "MIT",
  "authors": [
    {
      "name": "Ahmed Safaa",
      "email": "ahmed@sz4h.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.1|^8.2|^8.3|^8.4|^8.5",
    "intervention/image-laravel": "^1.0",
    "spatie/laravel-package-tools": "^1.9.2",
    "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0"
  },
  "autoload": {
    "files": [
      "helpers/helpers.php"
    ],
    "psr-4": {
      "Space\\Image\\": "src",
      "Space\\Image\\Database\\Factories\\": "database/factories"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Space\\Image\\Tests\\": "tests"
    }
  },
  "scripts": {
    "analyse": "vendor/bin/phpstan analyse",
    "test": "vendor/bin/pest",
    "test-coverage": "vendor/bin/pest --coverage",
    "format": "vendor/bin/pint"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Space\\Image\\ImageServiceProvider"
      ],
      "aliases": {
        "Image": "Space\\Image\\Facades\\Image"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
